{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "PT-NOTE",
  "version": "0.1.3",
  "identifier": "com.ptclinic.progressnote",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "PT-NOTE",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk4QzA2QjQ0OENBMkU4NTcKUldSWDZLS01SR3ZBbUF3aEwxeDBQWmJsQVhQWmJJL1h2dzRQbm1nY21EeTk0V21SYU45M2tWenkK",
      "endpoints": [
        "https://github.com/tone7718-droid/PT-Progress-Note/releases/latest/download/latest.json"
      ]
    }
  }
}
